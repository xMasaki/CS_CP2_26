<Window x:Class="CP2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CP2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Button Click="Inserir_Click" Content="Inserir aluno" HorizontalAlignment="Left" Margin="106,143,0,0" VerticalAlignment="Top" Width="84"/>
        <Button Click="Listar_Click" Content="Listar aluno" HorizontalAlignment="Left" Margin="230,143,0,0" VerticalAlignment="Top" Width="84"/>
        <Button Click="Atualizar_Click" Content="Atualizar aluno" HorizontalAlignment="Center" Margin="0,143,0,0" VerticalAlignment="Top"/>
        <Button Click="Remover_Click" Content="Remover aluno" HorizontalAlignment="Left" Margin="482,143,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="textoId" HorizontalAlignment="Left" Height="20" Margin="154,29,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="textoNome" HorizontalAlignment="Left" Margin="154,60,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox x:Name="textoIdade" HorizontalAlignment="Left" Margin="154,88,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBlock HorizontalAlignment="Left" Margin="106,31,0,0" TextWrapping="Wrap" Text="ID" VerticalAlignment="Top"/>
        <TextBlock HorizontalAlignment="Left" Margin="106,61,0,0" TextWrapping="Wrap" Text="Nome" VerticalAlignment="Top"/>
        <TextBlock HorizontalAlignment="Left" Margin="106,88,0,0" TextWrapping="Wrap" Text="Idade" VerticalAlignment="Top"/>
        <DataGrid x:Name="listaAlunos" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="70,188,70,118"/>
        <Button Click="Sair_Click" Content="Sair" HorizontalAlignment="Left" Margin="610,143,0,0" VerticalAlignment="Top" Width="84"/>
        <TextBlock HorizontalAlignment="Left" Margin="70,334,0,0" TextWrapping="Wrap" Text="Busca por ID:" VerticalAlignment="Top" FontSize="14" FontWeight="Bold"/>
        <TextBox x:Name="textoBuscar" HorizontalAlignment="Left" Margin="70,366,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <Button Click="Buscar_Click" Content="Buscar" HorizontalAlignment="Left" Margin="233,365,0,0" VerticalAlignment="Top"/>

    </Grid>
</Window>
